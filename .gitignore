# =============================================================================
# j-hack-stack — public template repo
# =============================================================================
# Rule: commit structure, templates, and empty framework files. Ignore event-generated content.
# Teams cloning this repo should work in their own private fork once they
# start populating real events.
# =============================================================================

# -----------------------------------------------------------------------------
# Event content — generated per hackathon, not part of the template
# -----------------------------------------------------------------------------

# All project event folders except the template
projects/*/
!projects/_template/

# -----------------------------------------------------------------------------
# Secrets and environment
# -----------------------------------------------------------------------------
.env
.env.*
.env.local
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# -----------------------------------------------------------------------------
# Build artifacts (from projects/*/src/ — language-agnostic)
# Note: add a language-specific .gitignore inside each project's src/ folder
# -----------------------------------------------------------------------------
node_modules/
__pycache__/
*.py[cod]
*.pyc
.venv/
venv/
dist/
build/
*.egg-info/
.next/
.nuxt/
out/
*.class
target/
.gradle/
